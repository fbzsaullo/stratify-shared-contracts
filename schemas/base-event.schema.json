{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stratify.gg/schemas/base-event.json",
  "title": "StratifyBaseEvent",
  "description": "Estrutura base de todos os eventos Stratify.",
  "type": "object",
  "required": ["event_type", "schema_version", "occurred_at", "match_id", "game"],
  "properties": {
    "event_type": {
      "type": "string",
      "description": "Tipo do evento em PascalCase"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Versão do schema semântico (MAJOR.MINOR)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp do momento do evento"
    },
    "match_id": {
      "type": "string",
      "description": "UUID da partida"
    },
    "player_id": {
      "type": "string",
      "description": "UUID do jogador (opcional em eventos de partida)"
    },
    "game": {
      "type": "string",
      "enum": ["cs2", "valorant", "dota2"],
      "description": "Identificador do jogo"
    },
    "payload": {
      "type": "object",
      "description": "Dados específicos do evento"
    }
  }
}
